# ---- Source ----
FOSRC_SERVER_LINK=https://open-science.canada.ca

# ---- Number of PDFs to process (leave blank for ALL) ----
NUM_PDFS_TO_PROCESS=10

# ---- Playwright ----
MAX_PLAYWRIGHT_WORKERS=5
PDFS_PER_WORKER=100

# ---- GROBID ----
GROBID_URL=http://localhost:8070

# ---- AWS / Bedrock ----
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ca-central-1
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
CITATION_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0

# ---- S3 ----
S3_BUCKET_NAME=your-figures-bucket
S3_PUBLIC_BASE_URL=

# ---- Pinecone ----
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=open-science-articles
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1024

# ---- Concurrency ----
MAX_DOWNLOAD_CONCURRENCY=5
MAX_PROCESS_WORKERS=4

# ---- Temp dir ----
TEMP_DIR=./tmp